<% layout("layouts/boilerplate") %>

<div class="new-page login-page">

    <div class="container py-5">

        <div class="row justify-content-center align-items-center">

            <div class="col-lg-6 col-md-8">

                <div class="new-listing-card login-card">

                    <!-- HEADER -->
                    <div class="form-header text-center">

                        <div class="form-icon login-icon">
                            <i class="fa-solid fa-right-to-bracket"></i>
                        </div>

                        <h1>Welcome Back</h1>

                        <p>
                            Login to continue exploring premium stays.
                        </p>

                    </div>

                    <!-- FORM -->
                    <form 
                        method="POST" 
                        action="/login"
                        class="needs-validation"
                        novalidate
                    >

                        <!-- USERNAME -->
                        <div class="floating-group">

                            <input
                                type="text"
                                id="username"
                                name="username"
                                class="custom-input"
                                placeholder=" "
                                required
                            >

                            <label for="username">
                                Username
                            </label>

                            <div class="valid-feedback">
                                Looks good!
                            </div>

                            <div class="invalid-feedback">
                                Please enter your username.
                            </div>

                        </div>

                        <!-- PASSWORD -->
                        <div class="floating-group password-group">

                            <input
                                type="password"
                                id="password"
                                name="password"
                                class="custom-input"
                                placeholder=" "
                                required
                            >

                            <label for="password">
                                Password
                            </label>

                            <div class="invalid-feedback">
                                Please enter your password.
                            </div>

                        </div>

                        <!-- OPTIONS -->
                        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">

                            <div class="form-check">

                                <input 
                                    class="form-check-input"
                                    type="checkbox"
                                    id="remember"
                                >

                                <label class="form-check-label remember-label" for="remember">
                                    Remember me
                                </label>

                            </div>

                            <a href="#" class="forgot-link">
                                Forgot Password?
                            </a>

                        </div>

                        <!-- BUTTON -->
                        <button class="create-btn login-btn">

                            <i class="fa-solid fa-lock-open"></i>
                            Login

                        </button>

                        <!-- SIGNUP -->
                        <div class="text-center mt-4">

                            <p class="bottom-text">

                                Don’t have an account?

                                <a href="/signup" class="signup-link">
                                    Create one
                                </a>

                            </p>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>